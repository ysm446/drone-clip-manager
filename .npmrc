# ネイティブ依存（better-sqlite3）を Electron ABI の「プレビルド」で取得する設定。
# これにより Visual Studio / node-gyp でのソースビルドを回避できる（Windows で VS 未検出でも install が通る）。
# target は devDependencies の electron のバージョンに合わせること（メジャーが変わったら更新する）。
runtime=electron
target=33.4.11
disturl=https://electronjs.org/headers
build-from-source=false
